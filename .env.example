# ─── LLM Backend ──────────────────────────────────────────────
# Leave OPENROUTER_API_KEY unset to use the Claude Code CLI instead.

# OpenRouter — set this to enable the OpenRouter backend
OPENROUTER_API_KEY=

# Model to use for all agent calls (any OpenRouter model ID).
# Defaults to anthropic/claude-haiku-4-5-20251001 if not set.
OPENROUTER_MODEL=anthropic/claude-haiku-4-5-20251001

# Per-tier overrides (optional — override OPENROUTER_MODEL for specific tiers)
OPENROUTER_MODEL_HAIKU=anthropic/claude-haiku-4-5-20251001
OPENROUTER_MODEL_SONNET=anthropic/claude-sonnet-4-6
OPENROUTER_MODEL_OPUS=anthropic/claude-opus-4-6

# Example: run all agents on Llama 3.1 8B, interviews on Sonnet
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# OPENROUTER_MODEL_SONNET=anthropic/claude-sonnet-4-6

# Model used for the /api/interview endpoint specifically
INTERVIEW_MODEL=haiku

# ─── Simulation ────────────────────────────────────────────────
# Max concurrent LLM calls (CLI mode) or fetch requests (OpenRouter mode)
CLAUDE_CONCURRENCY=4
